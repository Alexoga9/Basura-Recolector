; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Basura recolector"
run/main_scene="uid://rvr7pqnbebp8"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://Assets/icon.svg"

[autoload]

SignalBus="*uid://de1hm7ggjo12u"
Global="*uid://50g7q8nvqdp2"
Inventario="*uid://bxxsc2sciuuu3"

[debug]

gdscript/warnings/enable=false

[display]

window/size/viewport_width=368
window/size/viewport_height=208
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/SimpleFormatOnSave/plugin.cfg", "res://addons/kanban_tasks/plugin.cfg", "res://addons/ridiculous_coding/plugin.cfg", "res://addons/script_splitter/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Commons/": "blue",
"res://Entidades/": "orange",
"res://Escenario/": "pink",
"res://Escenarios/": "yellow",
"res://Recursos/": "gray",
"res://UI/": "green",
"res://Utilidades/": "purple"
}

